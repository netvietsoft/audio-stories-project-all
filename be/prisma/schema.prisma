generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String    @id @default(uuid()) @db.VarChar(36)
  email                String    @unique @db.VarChar(255)
  passwordHash         String?   @map("password_hash") @db.VarChar(255)
  displayName          String    @map("display_name") @db.VarChar(100)
  avatarUrl            String?   @map("avatar_url") @db.Text
  roleId               Int       @default(4) @map("role_id") @db.UnsignedInt
  pulseBalance         Int       @default(0) @map("credits") @db.UnsignedInt
  googleId             String?   @unique @map("google_id") @db.VarChar(100)
  stripeCustomerId     String?   @unique @map("stripe_customer_id") @db.VarChar(255)
  paypalCustomerId     String?   @unique @map("paypal_customer_id") @db.VarChar(255)
  isActive             Boolean   @default(true) @map("is_active")
  totalUnlockedStories Int       @default(0) @map("total_unlocked_stories") @db.UnsignedInt
  vipTier              Int       @default(0) @map("vip_tier") @db.UnsignedTinyInt
  vipExpirationDate    DateTime? @map("vip_expiration_date")
  emailVerifiedAt      DateTime? @map("email_verified_at")
  allowEmailNoti       Boolean   @default(true) @map("allow_email_noti")
  allowBellNoti        Boolean   @default(true) @map("allow_bell_noti")
  country              String?   @db.VarChar(100)
  lastLoginAt          DateTime? @map("last_login_at")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")
  deletedAt            DateTime? @map("deleted_at")

  role Role @relation(fields: [roleId], references: [id])

  oauthAccounts          OAuthAccount[]
  refreshTokens          RefreshToken[]
  authTokens             AuthToken[]
  userFavorites          UserFavorite[]
  userStorySubscriptions UserStorySubscription[]
  listeningHistory       ListeningHistory[]
  userFollowAuthors      UserFollowAuthor[]
  reviews                Review[]
  reviewLikes            ReviewLike[]
  reviewHelpfuls         ReviewHelpful[]
  reviewReplies          ReviewReply[]
  creditTransactions     CreditTransaction[]
  payments               Payment[]
  memberships            Membership[]
  notifications          Notification[]
  audioReports           AudioReport[]
  playlists              Playlist[]
  musicComments          MusicComment[]
  musicLikes             MusicLike[]
  musicCommentLikes      MusicCommentLike[]
  musicHistory           MusicHistory[]
  musicUnlocks           MusicUnlock[]
  musicPlaylists         MusicPlaylist[]
  chapterComments        ChapterComment[]
  commentReactions       CommentReaction[]
  commentReports         CommentReport[]
  userUnlockedVariants   UserUnlockedVariant[]
  chapterUnlocks         UserChapterUnlock[]
  storyUnlocks           UserStoryUnlock[]

  @@index([roleId])
  @@index([isActive])
  @@index([totalUnlockedStories])
  @@index([vipTier])
  @@index([deletedAt])
  @@index([vipExpirationDate])
  @@map("users")
}

model OAuthAccount {
  id             String   @id @default(uuid())
  provider       String   @db.VarChar(50)
  providerUserId String   @map("provider_user_id") @db.VarChar(255)
  profile        Json?
  userId         String   @map("user_id")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
  @@index([userId], map: "auth_oauth_account_user_id_fkey")
  @@map("auth_oauth_account")
}

model RefreshToken {
  id        String   @id @default(uuid()) @db.VarChar(36)
  userId    String   @map("user_id") @db.VarChar(36)
  /// JWT ID claim — stored instead of hashing the full token.
  /// JWT signature already guarantees integrity; jti uniqueness prevents replay.
  jti       String   @unique @db.VarChar(36)
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

enum AuthTokenType {
  VERIFY_EMAIL
  VERIFY_CODE
  PASSWORD_RESET
}

model AuthToken {
  id        String        @id @default(uuid()) @db.VarChar(36)
  userId    String        @map("user_id") @db.VarChar(36)
  type      AuthTokenType
  token     String        @unique @db.VarChar(512)
  expiresAt DateTime      @map("expires_at")
  isUsed    Boolean       @default(false) @map("is_used")
  createdAt DateTime      @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type])
  @@index([expiresAt])
  @@map("auth_tokens")
}

model Author {
  id             String   @id @default(uuid()) @db.VarChar(36)
  name           String   @db.VarChar(150)
  slug           String   @unique @db.VarChar(200)
  languageId     Int      @map("language_id") @db.UnsignedInt
  avatarUrl      String?  @map("avatar_url") @db.Text
  bio            String?  @db.Text
  followersCount Int      @default(0) @map("followers_count") @db.UnsignedInt
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  language          Language           @relation(fields: [languageId], references: [id])
  stories           Story[]
  userFollowAuthors UserFollowAuthor[]
  memberships       Membership[]

  @@index([name])
  @@index([languageId])
  @@map("authors")
}

model Role {
  id          Int      @id @default(autoincrement()) @db.UnsignedInt
  name        String   @unique @db.VarChar(50)
  slug        String   @unique @db.VarChar(50)
  description String?  @db.VarChar(255)
  permissions Json? // Restored
  createdAt   DateTime @default(now()) @map("created_at") // Restored

  users User[]

  @@map("roles")
}

model Language {
  id            Int             @id @default(autoincrement()) @db.UnsignedInt
  key           String          @unique @db.VarChar(16)
  name          String          @db.VarChar(120)
  isActive      Boolean         @default(true) @map("is_active")
  displayOrder  Int             @default(0) @map("display_order") @db.UnsignedInt
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")
  Author        Author[]
  Category      Category[]
  Story         Story[]
  Advertisement Advertisement[]
  Chapter       Chapter[]

  @@index([isActive, displayOrder])
  @@map("languages")
}

model Category {
  id          Int      @id @default(autoincrement()) @db.UnsignedInt
  name        String   @db.VarChar(100)
  slug        String   @db.VarChar(120)
  languageId  Int      @map("language_id") @db.UnsignedInt
  description String?  @db.Text
  iconUrl     String?  @map("icon_url") @db.VarChar(255)
  imageUrl    String?  @map("image_url") @db.Text
  createdAt   DateTime @default(now()) @map("created_at")

  language Language        @relation(fields: [languageId], references: [id])
  stories  StoryCategory[]

  @@unique([slug, languageId])
  @@index([languageId])
  @@map("categories")
}

model Label {
  id                  Int      @id @default(autoincrement()) @db.UnsignedInt
  name                String   @unique @db.VarChar(60)
  text                String   @db.VarChar(40)
  color               String   @db.VarChar(20)
  textColor           String?  @map("text_color") @db.VarChar(20)
  icon                String?  @db.VarChar(60)
  defaultDurationDays Int?     @map("default_duration_days") @db.UnsignedInt
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  stories Story[]

  @@map("labels")
}

enum StoryStatus {
  ongoing
  completed
}

enum MusicContentType {
  single
  podcast
  playlist
}

enum MusicAccessType {
  free
  vip
}

model Story {
  id             String      @id @default(uuid()) @db.VarChar(36)
  title          String      @db.VarChar(300)
  slug           String      @db.VarChar(350)
  languageId     Int         @map("language_id") @db.UnsignedInt
  description    String?     @db.Text
  thumbnailUrl   String?     @map("thumbnail_url") @db.Text
  authorId       String      @map("author_id") @db.VarChar(36)
  status         StoryStatus @default(ongoing)
  totalChapters  Int         @default(0) @map("total_chapters") @db.UnsignedInt
  totalViews     BigInt      @default(0) @map("total_views") @db.UnsignedBigInt
  averageRating  Decimal     @default(0) @map("average_rating") @db.Decimal(3, 2)
  ratingCount    Int         @default(0) @map("rating_count") @db.UnsignedInt
  isFeatured     Boolean     @default(false) @map("is_featured")
  isRecommended  Boolean     @default(false) @map("is_recommended")
  isInteractive  Boolean     @default(false) @map("is_interactive")
  featuredOrder  Int?        @map("featured_order")
  totalGifts     Int         @default(0) @map("total_gifts") @db.UnsignedInt
  favoritesCount Int         @default(0) @map("favorites_count") @db.UnsignedInt
  publishedAt    DateTime?   @map("published_at")
  audioUrl       String?     @map("audio_url") @db.Text
  unlockPrice    Int         @default(0) @map("unlock_price") @db.UnsignedInt
  discountPercent Int        @default(0) @map("discount_percent") @db.UnsignedInt
  labelId         Int?      @map("label_id") @db.UnsignedInt
  labelAssignedAt DateTime? @map("label_assigned_at")
  labelExpiresAt  DateTime? @map("label_expires_at")
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")
  deletedAt      DateTime?   @map("deleted_at")

  author                 Author                  @relation(fields: [authorId], references: [id])
  language               Language                @relation(fields: [languageId], references: [id])
  label                  Label?                  @relation(fields: [labelId], references: [id], onDelete: SetNull)
  categories             StoryCategory[]
  chapters               Chapter[]
  userFavorites          UserFavorite[]
  userStorySubscriptions UserStorySubscription[]
  listeningHistory       ListeningHistory[]
  reviews                Review[]
  audioReports           AudioReport[]
  playlistItems          PlaylistItem[]
  chapterComments        ChapterComment[]
  heroBanners            HeroBanner[]
  storyUnlocks           UserStoryUnlock[]

  @@unique([slug, languageId])
  @@index([title])
  @@index([authorId])
  @@index([status, isFeatured, publishedAt, updatedAt])
  @@index([totalViews])
  @@index([averageRating])
  @@index([isRecommended, updatedAt])
  @@index([isInteractive])
  @@index([languageId])
  @@index([labelId])
  @@map("stories")
}

model HeroBanner {
  id         String   @id @default(uuid()) @db.VarChar(36)
  titleVi    String   @map("title_vi") @db.VarChar(255)
  titleEn    String   @map("title_en") @db.VarChar(255)
  subtitleVi String?  @map("subtitle_vi") @db.VarChar(500)
  subtitleEn String?  @map("subtitle_en") @db.VarChar(500)
  imageUrl   String   @map("image_url") @db.Text
  targetUrl  String   @map("target_url") @db.VarChar(500)
  storyId    String?  @map("story_id") @db.VarChar(36)
  order      Int      @default(0) @map("display_order")
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  story Story? @relation(fields: [storyId], references: [id], onDelete: SetNull)

  @@index([storyId])
  @@index([isActive, order])
  @@index([createdAt])
  @@map("hero_banners")
}

enum AdvertisementContentType {
  image
  iframe
  youtube
}

model Advertisement {
  id          String                   @id @default(uuid()) @db.VarChar(36)
  partnerName String                   @map("partner_name") @db.VarChar(120)
  title       String                   @db.VarChar(255)
  contentType AdvertisementContentType @default(image) @map("content_type")
  imageUrl    String?                  @map("image_url") @db.Text
  targetUrl   String?                  @map("target_url") @db.VarChar(500)
  iframeCode  String?                  @map("iframe_code") @db.LongText
  youtubeId   String?                  @map("youtube_id") @db.VarChar(20)
  youtubePlayTime Int?                 @default(31) @map("youtube_play_time") @db.UnsignedInt
  isForcedRedirect Boolean             @default(false) @map("is_forced_redirect")
  clickCount  Int                      @default(0) @map("click_count") @db.UnsignedInt
  languageId  Int?                     @map("language_id") @db.UnsignedInt
  isGlobal    Boolean                  @default(true) @map("is_global")
  isActive    Boolean                  @default(true) @map("is_active")
  // 1 = inline, 2 = unlock-by-ad
  routeType   Int                      @default(1) @map("route_type")
  createdAt   DateTime                 @default(now()) @map("created_at")
  updatedAt   DateTime                 @updatedAt @map("updated_at")

  language Language? @relation(fields: [languageId], references: [id], onDelete: SetNull)

  // Chapters that are unlocked by this ad
  unlockedChapters Chapter[] @relation("UnlockAdForChapter")

  @@index([isActive, updatedAt])
  @@index([languageId])
  @@index([isGlobal])
  @@map("advertisements")
}

model Music {
  id                  String           @id @default(uuid()) @db.VarChar(36)
  title               String           @db.VarChar(300)
  slug                String           @unique @db.VarChar(350)
  artist              String           @db.VarChar(150)
  description         String?          @db.Text
  tags                Json?
  thumbnailUrl        String?          @map("thumbnail_url") @db.Text
  audioUrl            String           @map("audio_url") @db.VarChar(500)
  audioDuration       Int?             @map("audio_duration") @db.UnsignedInt
  contentType         MusicContentType @default(single) @map("content_type")
  accessType          MusicAccessType  @default(free) @map("access_type")
  originalUnlockPrice Int?             @map("original_unlock_price") @db.UnsignedInt
  discountPercent     Int              @default(0) @map("discount_percent") @db.UnsignedInt
  unlockPrice         Int              @default(0) @map("unlock_price") @db.UnsignedInt
  introEnabled        Boolean          @default(true) @map("intro_enabled")
  playlistTrackIds    Json?            @map("playlist_track_ids")
  playCount           Int              @default(0) @map("play_count") @db.UnsignedInt
  likeCount           Int              @default(0) @map("like_count") @db.UnsignedInt
  commentCount        Int              @default(0) @map("comment_count") @db.UnsignedInt
  isPublic            Boolean          @default(true) @map("is_public")
  createdAt           DateTime         @default(now()) @map("created_at")
  updatedAt           DateTime         @updatedAt @map("updated_at")

  comments        MusicComment[]
  likes           MusicLike[]
  historyEntries  MusicHistory[]
  playlistTracks  MusicPlaylistTrack[]
  unlocks         MusicUnlock[]        @relation("MusicUnlockTrack")
  unlocksAsSource MusicUnlock[]        @relation("MusicUnlockSourcePlaylist")

  @@index([isPublic])
  @@index([createdAt])
  @@index([contentType])
  @@index([playCount])
  @@index([likeCount])
  @@index([commentCount])
  @@map("music_tracks")
}

model MusicComment {
  id        String   @id @default(uuid()) @db.VarChar(36)
  userId    String   @map("user_id") @db.VarChar(36)
  musicId   String   @map("music_id") @db.VarChar(36)
  parentId  String?  @map("parent_id") @db.VarChar(36)
  content   String   @db.Text
  likeCount Int      @default(0) @map("like_count") @db.UnsignedInt
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user     User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  music    Music              @relation(fields: [musicId], references: [id], onDelete: Cascade)
  parent   MusicComment?      @relation("MusicCommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  children MusicComment[]     @relation("MusicCommentReplies")
  likes    MusicCommentLike[]

  @@index([userId])
  @@index([musicId])
  @@index([musicId, createdAt])
  @@index([parentId])
  @@map("music_comments")
}

model MusicCommentLike {
  userId    String   @map("user_id") @db.VarChar(36)
  commentId String   @map("comment_id") @db.VarChar(36)
  createdAt DateTime @default(now()) @map("created_at")

  user    User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  comment MusicComment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@id([userId, commentId])
  @@index([commentId])
  @@index([userId])
  @@map("music_comment_likes")
}

model MusicLike {
  id        String   @id @default(uuid()) @db.VarChar(36)
  userId    String   @map("user_id") @db.VarChar(36)
  musicId   String   @map("music_id") @db.VarChar(36)
  createdAt DateTime @default(now()) @map("created_at")

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  music Music @relation(fields: [musicId], references: [id], onDelete: Cascade)

  @@unique([userId, musicId])
  @@index([musicId])
  @@index([userId])
  @@map("music_likes")
}

model MusicHistory {
  id              String   @id @default(uuid()) @db.VarChar(36)
  userId          String   @map("user_id") @db.VarChar(36)
  musicId         String   @map("music_id") @db.VarChar(36)
  progressSeconds Int      @default(0) @map("progress_seconds") @db.UnsignedInt
  listenedAt      DateTime @default(now()) @map("listened_at")

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  music Music @relation(fields: [musicId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([musicId])
  @@index([userId, listenedAt])
  @@map("music_history")
}

enum MusicUnlockSourceType {
  track
  playlist
}

model MusicUnlock {
  id               String                @id @default(uuid()) @db.VarChar(36)
  userId           String                @map("user_id") @db.VarChar(36)
  musicId          String                @map("music_id") @db.VarChar(36)
  sourceType       MusicUnlockSourceType @default(track) @map("source_type")
  sourcePlaylistId String?               @map("source_playlist_id") @db.VarChar(36)
  pulseSpent       Int                   @default(0) @map("credits_spent") @db.UnsignedInt
  createdAt        DateTime              @default(now()) @map("created_at")

  user           User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  music          Music  @relation("MusicUnlockTrack", fields: [musicId], references: [id], onDelete: Cascade)
  sourcePlaylist Music? @relation("MusicUnlockSourcePlaylist", fields: [sourcePlaylistId], references: [id], onDelete: SetNull)

  @@unique([userId, musicId])
  @@index([userId])
  @@index([musicId])
  @@index([sourcePlaylistId])
  @@map("music_unlocks")
}

model MusicPlaylist {
  id         String   @id @default(uuid()) @db.VarChar(36)
  userId     String   @map("user_id") @db.VarChar(36)
  title      String   @db.VarChar(200)
  isPublic   Boolean  @default(false) @map("is_public")
  coverImage String?  @map("cover_image") @db.Text
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  user   User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  tracks MusicPlaylistTrack[]

  @@index([userId])
  @@index([isPublic])
  @@map("music_playlists")
}

model MusicPlaylistTrack {
  playlistId String   @map("playlist_id") @db.VarChar(36)
  musicId    String   @map("music_id") @db.VarChar(36)
  orderIndex Int      @default(0) @map("order_index") @db.UnsignedInt
  addedAt    DateTime @default(now()) @map("added_at")

  playlist MusicPlaylist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  music    Music         @relation(fields: [musicId], references: [id], onDelete: Cascade)

  @@id([playlistId, musicId])
  @@index([musicId])
  @@index([orderIndex])
  @@map("music_playlist_tracks")
}

model StoryCategory {
  storyId    String   @map("story_id") @db.VarChar(36)
  categoryId Int      @map("category_id") @db.UnsignedInt
  createdAt  DateTime @default(now()) @map("created_at")

  story    Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([storyId, categoryId])
  @@index([storyId])
  @@index([categoryId])
  @@map("story_categories")
}

enum ChapterAccessType {
  free
  timed
  vip
  ads
}

enum ChapterUnlockType {
  VIP
  TIMED
  PULSE
  AD
}

model Chapter {
  id             String            @id @default(uuid()) @db.VarChar(36)
  storyId        String?           @map("story_id") @db.VarChar(36)
  chapterNumber  Float             @map("chapter_number") @db.Float
  title          String?           @db.VarChar(300)
  languageId     Int               @map("language_id") @db.UnsignedInt
  description    String?           @db.Text
  thumbnailUrl   String?           @map("thumbnail_url") @db.Text
  content        String?           @db.LongText
  audioUrl       String?           @map("audio_url") @db.VarChar(500)
  r2AudioUrl     String?           @map("r2_audio_url") @db.VarChar(500)
  youtubeVideoId String?           @map("youtube_video_id") @db.VarChar(20)
  audioDuration  Int?              @map("audio_duration") @db.UnsignedInt
  timingJson     Json?             @map("timing_json")
  accessType     ChapterAccessType @default(free) @map("access_type")
  unlockPrice    Int               @default(0) @map("unlock_price") @db.UnsignedInt
  discountPercent Int              @default(0) @map("discount_percent") @db.UnsignedInt
  // If this chapter is unlocked by watching an ad, store the ad id here
  unlockAdId     String?           @map("unlock_ad_id") @db.VarChar(36)
  unlockAd       Advertisement?    @relation("UnlockAdForChapter", fields: [unlockAdId], references: [id], onDelete: SetNull)
  isInteractive  Boolean           @default(false) @map("is_interactive")
  unlocksAt      DateTime?         @map("unlocks_at")
  viewCount      BigInt            @default(0) @map("view_count") @db.UnsignedBigInt
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @updatedAt @map("updated_at")
  deletedAt      DateTime?         @map("deleted_at")

  story            Story?             @relation(fields: [storyId], references: [id], onDelete: Cascade)
  language         Language           @relation(fields: [languageId], references: [id])
  listeningHistory ListeningHistory[]
  audioReports     AudioReport[]
  playlistItems    PlaylistItem[]
  chapterComments  ChapterComment[]
  variants         ChapterVariant[]   @relation("ChapterVariants")
  incomingVariants ChapterVariant[]   @relation("VariantNextChapter")

  chapterUnlocks UserChapterUnlock[]

  @@unique([storyId, chapterNumber])
  @@index([accessType])
  @@index([unlocksAt])
  @@index([storyId, chapterNumber(sort: Asc)])
  @@index([languageId])
  @@map("chapters")
}

model UserFavorite {
  userId    String   @map("user_id") @db.VarChar(36)
  storyId   String   @map("story_id") @db.VarChar(36)
  createdAt DateTime @default(now()) @map("created_at")

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  story Story @relation(fields: [storyId], references: [id], onDelete: Cascade)

  @@id([userId, storyId])
  @@index([userId])
  @@index([storyId])
  @@index([userId, createdAt])
  @@map("user_favorites")
}

model UserStorySubscription {
  userId    String   @map("user_id") @db.VarChar(36)
  storyId   String   @map("story_id") @db.VarChar(36)
  createdAt DateTime @default(now()) @map("created_at")

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  story Story @relation(fields: [storyId], references: [id], onDelete: Cascade)

  @@id([userId, storyId])
  @@index([userId])
  @@index([storyId])
  @@index([userId, createdAt])
  @@map("user_story_subscriptions")
}

model ListeningHistory {
  id              String   @id @default(uuid()) @db.VarChar(36)
  userId          String   @map("user_id") @db.VarChar(36)
  storyId         String   @map("story_id") @db.VarChar(36)
  chapterId       String   @map("chapter_id") @db.VarChar(36)
  progressSeconds Int      @default(0) @map("progress_seconds") @db.UnsignedInt
  lastListenedAt  DateTime @default(now()) @map("last_listened_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  user    User            @relation(fields: [userId], references: [id], onDelete: Cascade)
