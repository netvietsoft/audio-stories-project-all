generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String    @id @default(uuid()) @db.VarChar(36)
  email                String    @unique @db.VarChar(255)
  passwordHash         String?   @map("password_hash") @db.VarChar(255)
  displayName          String    @map("display_name") @db.VarChar(100)
  avatarUrl            String?   @map("avatar_url") @db.Text
  roleId               Int       @default(4) @map("role_id") @db.UnsignedInt
  credits              Int       @default(0) @db.UnsignedInt
  googleId             String?   @unique @map("google_id") @db.VarChar(100)
  stripeCustomerId     String?   @unique @map("stripe_customer_id") @db.VarChar(255)
  paypalCustomerId     String?   @unique @map("paypal_customer_id") @db.VarChar(255)
  isActive             Boolean   @default(true) @map("is_active")
  totalUnlockedStories Int       @default(0) @map("total_unlocked_stories") @db.UnsignedInt
  vipTier              Int       @default(0) @map("vip_tier") @db.UnsignedTinyInt
  vipExpirationDate    DateTime? @map("vip_expiration_date")
  emailVerifiedAt      DateTime? @map("email_verified_at")
  allowEmailNoti       Boolean   @default(true) @map("allow_email_noti")
  allowBellNoti        Boolean   @default(true) @map("allow_bell_noti")
  country              String?   @db.VarChar(100)
  lastLoginAt          DateTime? @map("last_login_at")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")
  deletedAt            DateTime? @map("deleted_at")

  role Role @relation(fields: [roleId], references: [id])

  oauthAccounts       OAuthAccount[]
  refreshTokens       RefreshToken[]
  authTokens          AuthToken[]
  userFavorites       UserFavorite[]
  userStorySubscriptions UserStorySubscription[]
  listeningHistory    ListeningHistory[]
  userFollowAuthors   UserFollowAuthor[]
  reviews             Review[]
  reviewLikes         ReviewLike[]
  reviewHelpfuls      ReviewHelpful[]
  reviewReplies       ReviewReply[]
  creditTransactions  CreditTransaction[]
  payments            Payment[]
  memberships         Membership[]
  notifications       Notification[]
  audioReports        AudioReport[]
  playlists           Playlist[]
  chapterComments     ChapterComment[]
  commentReactions    CommentReaction[]
  commentReports      CommentReport[]
  userUnlockedVariants UserUnlockedVariant[]

  @@index([roleId])
  @@index([isActive])
  @@index([totalUnlockedStories])
  @@index([vipTier])
  @@index([deletedAt])
  @@index([vipExpirationDate])
  @@map("users")
}

model OAuthAccount {
  id             String   @id @default(uuid())
  provider       String   @db.VarChar(50)
  providerUserId String   @map("provider_user_id") @db.VarChar(255)
  profile        Json?
  userId         String   @map("user_id")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
  @@index([userId], map: "auth_oauth_account_user_id_fkey")
  @@map("auth_oauth_account")
}

model RefreshToken {
  id        String   @id @default(uuid()) @db.VarChar(36)
  userId    String   @map("user_id") @db.VarChar(36)
  token     String   @unique @db.VarChar(512)
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
  @@map("refresh_tokens")
}

enum AuthTokenType {
  VERIFY_EMAIL
  VERIFY_CODE
  PASSWORD_RESET
}

model AuthToken {
  id        String        @id @default(uuid()) @db.VarChar(36)
  userId    String        @map("user_id") @db.VarChar(36)
  type      AuthTokenType
  token     String        @unique @db.VarChar(512)
  expiresAt DateTime      @map("expires_at")
  isUsed    Boolean       @default(false) @map("is_used")
  createdAt DateTime      @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type])
  @@index([expiresAt])
  @@map("auth_tokens")
}

model Author {
  id             String   @id @default(uuid()) @db.VarChar(36)
  name           String   @db.VarChar(150)
  slug           String   @unique @db.VarChar(200)
  language       String   @default("vi") @db.VarChar(8)
  avatarUrl      String?  @map("avatar_url") @db.Text
  bio            String?  @db.Text
  followersCount Int      @default(0) @map("followers_count") @db.UnsignedInt
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  stories           Story[]
  userFollowAuthors UserFollowAuthor[]
  memberships       Membership[]

  @@index([name])
  @@index([language])
  @@map("authors")
}

model Role {
  id          Int      @id @default(autoincrement()) @db.UnsignedInt
  name        String   @unique @db.VarChar(50)
  slug        String   @unique @db.VarChar(50)
  description String?  @db.VarChar(255)
  permissions Json?    // Restored
  createdAt   DateTime @default(now()) @map("created_at") // Restored

  users User[]

  @@map("roles")
}

model Language {
  id           Int      @id @default(autoincrement()) @db.UnsignedInt
  key          String   @unique @db.VarChar(16)
  name         String   @db.VarChar(120)
  isActive     Boolean  @default(true) @map("is_active")
  displayOrder Int      @default(0) @map("display_order") @db.UnsignedInt
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([isActive, displayOrder])
  @@map("languages")
}

model Category {
  id          Int      @id @default(autoincrement()) @db.UnsignedInt
  name        String   @db.VarChar(100)
  slug        String   @db.VarChar(120)
  language    String   @default("vi") @db.VarChar(8)
  description String?  @db.Text
  iconUrl     String?  @map("icon_url") @db.VarChar(255)
  createdAt   DateTime @default(now()) @map("created_at")

  stories StoryCategory[]

  @@unique([slug, language])
  @@index([language])
  @@map("categories")
}

enum StoryStatus {
  ongoing
  completed
}

model Story {
  id            String      @id @default(uuid()) @db.VarChar(36)
  title         String      @db.VarChar(300)
  slug          String      @db.VarChar(350)
  language      String      @default("vi") @db.VarChar(8)
  description   String?     @db.Text
  thumbnailUrl  String?     @map("thumbnail_url") @db.Text
  authorId      String      @map("author_id") @db.VarChar(36)
  status        StoryStatus @default(ongoing)
  totalChapters Int         @default(0) @map("total_chapters") @db.UnsignedInt
  totalViews    BigInt      @default(0) @map("total_views") @db.UnsignedBigInt
  averageRating Decimal     @default(0) @map("average_rating") @db.Decimal(3, 2)
  ratingCount   Int         @default(0) @map("rating_count") @db.UnsignedInt
  isFeatured    Boolean     @default(false) @map("is_featured")
  isRecommended Boolean     @default(false) @map("is_recommended")
  isInteractive Boolean     @default(false) @map("is_interactive")
  featuredOrder Int?        @map("featured_order")
  totalGifts    Int         @default(0) @map("total_gifts") @db.UnsignedInt
  favoritesCount Int        @default(0) @map("favorites_count") @db.UnsignedInt
  publishedAt   DateTime?   @map("published_at")
  audioUrl          String?     @map("audio_url") @db.Text
  facebookGroupUrl  String?     @map("facebook_group_url") @db.VarChar(500)
  twitterUrl        String?     @map("twitter_url") @db.VarChar(500)
  instagramUrl      String?     @map("instagram_url") @db.VarChar(500)
  redditUrl         String?     @map("reddit_url") @db.VarChar(500)
  whatsappUrl       String?     @map("whatsapp_url") @db.VarChar(500)
  createdAt         DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")
  deletedAt     DateTime?   @map("deleted_at")

  author           Author             @relation(fields: [authorId], references: [id])
  categories       StoryCategory[]
  chapters         Chapter[]
  userFavorites    UserFavorite[]
  userStorySubscriptions UserStorySubscription[]
  listeningHistory ListeningHistory[]
  reviews          Review[]
  audioReports     AudioReport[]
  playlistItems    PlaylistItem[]
  chapterComments  ChapterComment[]
  heroBanners      HeroBanner[]

  @@unique([slug, language])
  @@index([title])
  @@index([authorId])
  @@index([status, isFeatured, publishedAt, updatedAt])
  @@index([totalViews])
  @@index([averageRating])
  @@index([isRecommended, updatedAt])
  @@index([isInteractive])
  @@index([language])
  @@map("stories")
}

model HeroBanner {
  id         String   @id @default(uuid()) @db.VarChar(36)
  titleVi    String   @map("title_vi") @db.VarChar(255)
  titleEn    String   @map("title_en") @db.VarChar(255)
  subtitleVi String?  @map("subtitle_vi") @db.VarChar(500)
  subtitleEn String?  @map("subtitle_en") @db.VarChar(500)
  imageUrl   String   @map("image_url") @db.Text
  targetUrl  String   @map("target_url") @db.VarChar(500)
  storyId    String?  @map("story_id") @db.VarChar(36)
  order      Int      @default(0) @map("display_order")
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  story Story? @relation(fields: [storyId], references: [id], onDelete: SetNull)

  @@index([storyId])
  @@index([isActive, order])
  @@index([createdAt])
  @@map("hero_banners")
}

model Advertisement {
  id          String   @id @default(uuid()) @db.VarChar(36)
  partnerName String   @map("partner_name") @db.VarChar(120)
  title       String   @db.VarChar(255)
  imageUrl    String   @map("image_url") @db.Text
  targetUrl   String   @map("target_url") @db.VarChar(500)
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([isActive, updatedAt])
  @@map("advertisements")
}

model StoryCategory {
  storyId    String   @map("story_id") @db.VarChar(36)
  categoryId Int      @map("category_id") @db.UnsignedInt
  createdAt  DateTime @default(now()) @map("created_at")

  story    Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([storyId, categoryId])
  @@index([storyId])
  @@index([categoryId])
  @@map("story_categories")
}

enum ChapterAccessType {
  free
  timed
  vip
}

model Chapter {
  id             String            @id @default(uuid()) @db.VarChar(36)
  storyId        String?           @map("story_id") @db.VarChar(36)
  chapterNumber  Float             @map("chapter_number") @db.Float
  title          String            @db.VarChar(300)
  language       String            @default("vi") @db.VarChar(8)
  description    String?           @db.Text
  thumbnailUrl   String?           @map("thumbnail_url") @db.Text
  content        String?           @db.LongText
  audioUrl       String?           @map("audio_url") @db.VarChar(500)
  r2AudioUrl     String?           @map("r2_audio_url") @db.VarChar(500)
  youtubeVideoId String?           @map("youtube_video_id") @db.VarChar(20)
  audioDuration  Int?              @map("audio_duration") @db.UnsignedInt
  accessType     ChapterAccessType @default(free) @map("access_type")
  isInteractive  Boolean           @default(false) @map("is_interactive")
  unlocksAt      DateTime?         @map("unlocks_at")
  viewCount      BigInt            @default(0) @map("view_count") @db.UnsignedBigInt
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @updatedAt @map("updated_at")
  deletedAt      DateTime?         @map("deleted_at")

  story            Story?             @relation(fields: [storyId], references: [id], onDelete: Cascade)
  listeningHistory ListeningHistory[]
  audioReports     AudioReport[]
  playlistItems    PlaylistItem[]
  chapterComments  ChapterComment[]
  variants         ChapterVariant[] @relation("ChapterVariants")
  incomingVariants ChapterVariant[] @relation("VariantNextChapter")

  @@unique([storyId, chapterNumber])
  @@index([accessType])
  @@index([unlocksAt])
  @@index([storyId, chapterNumber(sort: Asc)])
  @@index([language])
  @@map("chapters")
}

model UserFavorite {
  userId    String   @map("user_id") @db.VarChar(36)
  storyId   String   @map("story_id") @db.VarChar(36)
  createdAt DateTime @default(now()) @map("created_at")

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  story Story @relation(fields: [storyId], references: [id], onDelete: Cascade)

  @@id([userId, storyId])
  @@index([userId])
  @@index([storyId])
  @@index([userId, createdAt])
  @@map("user_favorites")
}

model UserStorySubscription {
  userId    String   @map("user_id") @db.VarChar(36)
  storyId   String   @map("story_id") @db.VarChar(36)
  createdAt DateTime @default(now()) @map("created_at")

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  story Story @relation(fields: [storyId], references: [id], onDelete: Cascade)

  @@id([userId, storyId])
  @@index([userId])
  @@index([storyId])
  @@index([userId, createdAt])
  @@map("user_story_subscriptions")
}

model ListeningHistory {
  id              String   @id @default(uuid()) @db.VarChar(36)
  userId          String   @map("user_id") @db.VarChar(36)
  storyId         String   @map("story_id") @db.VarChar(36)
  chapterId       String   @map("chapter_id") @db.VarChar(36)
  progressSeconds Int      @default(0) @map("progress_seconds") @db.UnsignedInt
  lastListenedAt  DateTime @default(now()) @map("last_listened_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  story   Story   @relation(fields: [storyId], references: [id], onDelete: Cascade)
  chapter Chapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  variant ChapterVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  variantId String? @map("variant_id") @db.VarChar(36)

  @@unique([userId, chapterId, variantId])
  @@index([userId])
  @@index([chapterId])
  @@index([storyId])
  @@index([lastListenedAt])
  @@index([userId, lastListenedAt])
  @@map("listening_history")
}

model UserFollowAuthor {
  userId    String   @map("user_id") @db.VarChar(36)
  authorId  String   @map("author_id") @db.VarChar(36)
  createdAt DateTime @default(now()) @map("created_at")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  author Author @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@id([userId, authorId])
  @@index([userId])
  @@index([authorId])
  @@map("user_follow_authors")
}

model Review {
  id         String   @id @default(uuid()) @db.VarChar(36)
  userId     String   @map("user_id") @db.VarChar(36)
  storyId    String   @map("story_id") @db.VarChar(36)
  rating     Int      @db.TinyInt
  content    String?  @db.Text
  likesCount Int      @default(0) @map("likes_count") @db.UnsignedInt
  helpfulCount Int    @default(0) @map("helpful_count") @db.UnsignedInt
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  story       Story        @relation(fields: [storyId], references: [id], onDelete: Cascade)
  reviewLikes ReviewLike[]
  reviewHelpfuls ReviewHelpful[]
  replies     ReviewReply[]

  @@unique([userId, storyId])
  @@index([userId])
  @@index([storyId])
  @@index([storyId, createdAt])
  @@index([storyId, likesCount])
  @@index([storyId, helpfulCount])
  @@map("reviews")
}

model ReviewLike {
  userId    String   @map("user_id") @db.VarChar(36)
  reviewId  String   @map("review_id") @db.VarChar(36)
  createdAt DateTime @default(now()) @map("created_at")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  review Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@id([userId, reviewId])
  @@index([userId])
  @@index([reviewId])
  @@map("review_likes")
}

model ReviewHelpful {
  userId    String   @map("user_id") @db.VarChar(36)
  reviewId  String   @map("review_id") @db.VarChar(36)
  createdAt DateTime @default(now()) @map("created_at")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  review Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@id([userId, reviewId])
  @@index([userId])
  @@index([reviewId])
  @@map("review_helpful")
}

model ReviewReply {
  id        String   @id @default(uuid()) @db.VarChar(36)
  reviewId  String   @map("review_id") @db.VarChar(36)
  userId    String   @map("user_id") @db.VarChar(36)
  parentId  String?  @map("parent_id") @db.VarChar(36)
  content   String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  review   Review        @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent   ReviewReply?  @relation("ReviewReplyChildren", fields: [parentId], references: [id], onDelete: Cascade)
  children ReviewReply[] @relation("ReviewReplyChildren")

  @@index([reviewId, createdAt])
  @@index([userId])
  @@index([parentId])
  @@map("review_replies")
}

enum CreditTransactionType {
  topup
  spend
  refund
  admin_adjust
}

model CreditTransaction {
  id            String                @id @default(uuid()) @db.VarChar(36)
  userId        String                @map("user_id") @db.VarChar(36)
  type          CreditTransactionType
  amount        Int
  balanceBefore Int                   @map("balance_before") @db.UnsignedInt
  balanceAfter  Int                   @map("balance_after") @db.UnsignedInt
  referenceId   String?               @map("reference_id") @db.VarChar(36)
  description   String?               @db.VarChar(255)
  createdAt     DateTime              @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([userId, createdAt])
  @@index([type, createdAt])
  @@index([referenceId])
  @@map("credit_transactions")
}

enum PaymentProvider {
  STRIPE
  VIETQR
  PAYPAL
  MANUAL
}

enum PaymentStatus {
  PENDING
  PROCESSING
  SUCCESS
  SUCCEEDED
  FAILED
  CANCELLED
  REFUNDED
  PARTIALLY_REFUNDED
  REQUIRES_ACTION
  REQUIRES_PAYMENT_METHOD
}

model Payment {
  id                     String          @id @default(uuid()) @db.VarChar(36)
  userId                 String          @map("user_id") @db.VarChar(36)
  packageCode            String          @map("package_code") @db.VarChar(50)
  amountVnd              Int             @map("amount_vnd") @db.UnsignedInt
  amountUsd              Decimal?        @map("amount_usd") @db.Decimal(10, 2)
  creditsAdded           Int             @map("credits_added") @db.UnsignedInt
  provider               PaymentProvider @default(VIETQR)
  providerPaymentId      String?         @map("provider_payment_id") @db.VarChar(255)
  providerCustomerId     String?         @map("provider_customer_id") @db.VarChar(255)
  status                 PaymentStatus   @default(PENDING)
  currency               String          @default("VND") @db.VarChar(3)
  qrData                 String?         @map("qr_data") @db.Text
  qrImageBase64          String?         @map("qr_image_base64") @db.LongText
  transactionCode        String?         @map("transaction_code") @db.VarChar(100)
  bankTransactionId      String?         @map("bank_transaction_id") @db.VarChar(255)
  receiptUrl             String?         @map("receipt_url") @db.VarChar(500)
  failureMessage         String?         @map("failure_message") @db.Text
  metadata               Json?
  paidAt                 DateTime?       @map("paid_at")
  failedAt               DateTime?       @map("failed_at")
  expiresAt              DateTime        @map("expires_at")
  createdAt              DateTime        @default(now()) @map("created_at")
  updatedAt              DateTime        @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])

  @@unique([provider, providerPaymentId])
  @@index([userId])
  @@index([status, expiresAt])
  @@index([transactionCode])
  @@index([userId, status])
  @@index([provider])
  @@map("payments")
}

model WebhookEvent {
  id            String    @id @default(uuid()) @db.VarChar(36)
  provider      String    @db.VarChar(50)
  eventType     String    @map("event_type") @db.VarChar(100)
  eventId       String    @map("event_id") @db.VarChar(255)
  payload       Json
  processed     Boolean   @default(false)
  processedAt   DateTime? @map("processed_at")
  errorMessage  String?   @map("error_message") @db.Text
  retryCount    Int       @default(0) @map("retry_count")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@unique([provider, eventId])
  @@index([provider, eventType])
  @@index([processed])
  @@index([createdAt])
  @@map("webhook_events")
}

enum MembershipType {
  all_authors
  specific_author
}

model Membership {
  id           String         @id @default(uuid()) @db.VarChar(36)
  userId       String         @map("user_id") @db.VarChar(36)
  type         MembershipType
  authorId     String?        @map("author_id") @db.VarChar(36)
  startDate    DateTime       @map("start_date")
  endDate      DateTime       @map("end_date")
  creditsSpent Int            @map("credits_spent") @db.UnsignedInt
  createdAt    DateTime       @default(now()) @map("created_at")

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  author Author? @relation(fields: [authorId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([authorId])
  @@index([userId, type, authorId, endDate])
  @@index([endDate])
  @@map("memberships")
}

enum NotificationType {
  new_chapter
  transaction
  membership_expiry
  system
}

model Notification {
  id        String           @id @default(uuid()) @db.VarChar(36)
  userId    String           @map("user_id") @db.VarChar(36)
  type      NotificationType
  title     String           @db.VarChar(255)
  body      String           @db.Text
  isRead    Boolean          @default(false) @map("is_read")
  metadata  Json?
  createdAt DateTime         @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, isRead, createdAt])
  @@index([type, createdAt])
  @@map("notifications")
}

enum SettingType {
  string
  number
  boolean
  json
}

model SiteSetting {
  key         String      @id @unique @db.VarChar(100)
  value       String?     @db.Text
  type        SettingType @default(string)
  description String?     @db.VarChar(255)
  updatedAt   DateTime    @updatedAt @map("updated_at")

  @@map("site_settings")
}

model SystemConfig {
  key       String   @id @unique @db.VarChar(100)
  value     String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("system_configs")
}

model Banner {
  id         Int       @id @default(autoincrement()) @db.UnsignedInt
  title      String    @db.VarChar(255)
  imageUrl   String    @map("image_url") @db.Text
  linkUrl    String?   @map("link_url") @db.VarChar(500)
  position   String    @default("home_hero") @db.VarChar(50)
  orderIndex Int       @default(0) @map("order_index") @db.UnsignedInt
  isActive   Boolean   @default(true) @map("is_active")
  startDate  DateTime? @map("start_date")
  endDate    DateTime? @map("end_date")
  createdAt  DateTime  @default(now()) @map("created_at")

  @@index([position])
  @@index([orderIndex])
  @@index([isActive])
  @@index([startDate, endDate])
  @@map("banners")
}

enum AudioReportType {
  broken_link
  bad_quality
  missing_audio
  wrong_chapter
  other
}

enum AudioReportStatus {
  pending
  resolved
  ignored
}

model AudioReport {
  id         String            @id @default(uuid()) @db.VarChar(36)
  userId     String?           @map("user_id") @db.VarChar(36)
  chapterId  String            @map("chapter_id") @db.VarChar(36)
  storyId    String            @map("story_id") @db.VarChar(36)
  type       AudioReportType
  note       String?           @db.Text
  status     AudioReportStatus @default(pending)
  adminNote  String?           @map("admin_note") @db.Text
  resolvedAt DateTime?         @map("resolved_at")
  createdAt  DateTime          @default(now()) @map("created_at")

  user    User?   @relation(fields: [userId], references: [id], onDelete: SetNull)
  chapter Chapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  story   Story   @relation(fields: [storyId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([chapterId])
  @@index([storyId])
  @@index([type])
  @@index([status])
  @@index([createdAt])
  @@map("audio_reports")
}

model Playlist {
  id         String   @id @default(uuid()) @db.VarChar(36)
  userId     String   @map("user_id") @db.VarChar(36)
  name       String   @db.VarChar(200)
  coverUrl   String?  @map("cover_url") @db.Text
  totalItems Int      @default(0) @map("total_items") @db.UnsignedInt
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  playlistItems PlaylistItem[]

  @@index([userId])
  @@map("playlists")
}

model PlaylistItem {
  id         String   @id @default(uuid()) @db.VarChar(36)
  playlistId String   @map("playlist_id") @db.VarChar(36)
  chapterId  String   @map("chapter_id") @db.VarChar(36)
  storyId    String   @map("story_id") @db.VarChar(36)
  orderIndex Int      @default(0) @map("order_index") @db.UnsignedInt
  addedAt    DateTime @default(now()) @map("added_at")

  playlist Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  chapter  Chapter  @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  story    Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)

  @@index([playlistId])
  @@index([chapterId])
  @@index([storyId])
  @@index([orderIndex])
  @@map("playlist_items")
}

model ChapterComment {
  id               String   @id @default(uuid()) @db.VarChar(36)
  userId           String   @map("user_id") @db.VarChar(36)
  chapterId        String   @map("chapter_id") @db.VarChar(36)
  storyId          String   @map("story_id") @db.VarChar(36)
  parentId         String?  @map("parent_id") @db.VarChar(36)
  content          String   @db.Text
  timestampSeconds Int?     @map("timestamp_seconds") @db.UnsignedInt
  likesCount       Int      @default(0) @map("likes_count") @db.UnsignedInt
  isHidden         Boolean  @default(false) @map("is_hidden")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  user    User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  chapter   Chapter          @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  story     Story            @relation(fields: [storyId], references: [id], onDelete: Cascade)
  parent    ChapterComment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies   ChapterComment[] @relation("CommentReplies")
  reactions CommentReaction[]
  reports   CommentReport[]
  variant   ChapterVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  variantId String? @map("variant_id") @db.VarChar(36)

  @@index([userId])
  @@index([chapterId])
  @@index([storyId])
  @@index([parentId])
  @@index([isHidden])
  @@index([createdAt])
  @@map("chapter_comments")
}

enum CommentReactionType {
  helpful
  like
  love
}

model CommentReaction {
  id        String              @id @default(uuid()) @db.VarChar(36)
  userId    String              @map("user_id") @db.VarChar(36)
  commentId String              @map("comment_id") @db.VarChar(36)
  type      CommentReactionType
  createdAt DateTime            @default(now()) @map("created_at")

  user    User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  comment ChapterComment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([userId, commentId, type])
  @@index([commentId])
  @@index([userId])
  @@index([commentId, type])
  @@map("comment_reactions")
}

enum CommentReportStatus {
  pending
  reviewed
  resolved
  dismissed
}

model CommentReport {
  id        String              @id @default(uuid()) @db.VarChar(36)
  userId    String?             @map("user_id") @db.VarChar(36)
  commentId String              @map("comment_id") @db.VarChar(36)
  reason    String              @db.Text
  status    CommentReportStatus @default(pending)
  adminNote String?             @map("admin_note") @db.Text
  createdAt DateTime            @default(now()) @map("created_at")
  updatedAt DateTime            @updatedAt @map("updated_at")

  user    User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  comment ChapterComment  @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([commentId])
  @@index([status])
  @@index([createdAt])
  @@map("comment_reports")
}

model ChapterVariant {
  id             String    @id @default(uuid()) @db.VarChar(36)
  chapterId      String    @map("chapter_id") @db.VarChar(36)
  nextChapterId  String?   @map("next_chapter_id") @db.VarChar(36)
  nextVariantId  String?   @map("next_variant_id") @db.VarChar(36)
  title          String    @db.VarChar(300)
  description    String?   @db.Text
  content        String?   @db.LongText
  audioUrl       String?   @map("audio_url") @db.VarChar(500)
  r2AudioUrl     String?   @map("r2_audio_url") @db.VarChar(500)
  audioDuration  Int?      @map("audio_duration") @db.UnsignedInt
  unlockPrice    Int       @default(0) @map("unlock_price") @db.UnsignedInt
  orderIndex     Int       @default(0) @map("order_index") @db.UnsignedInt
  isDefault      Boolean   @default(false) @map("is_default")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  chapter      Chapter  @relation("ChapterVariants", fields: [chapterId], references: [id], onDelete: Cascade)
  nextChapter  Chapter? @relation("VariantNextChapter", fields: [nextChapterId], references: [id], onDelete: SetNull)
  userUnlockedVariants UserUnlockedVariant[]
  listeningHistory ListeningHistory[]
  chapterComments  ChapterComment[]
  
  @@index([chapterId])
  @@index([nextChapterId])
  @@map("chapter_variants")
}

model UserUnlockedVariant {
  userId    String   @map("user_id") @db.VarChar(36)
  variantId String   @map("variant_id") @db.VarChar(36)
  unlockedAt DateTime @default(now()) @map("unlocked_at")

  user    User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  variant ChapterVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@id([userId, variantId])
  @@index([userId])
  @@index([variantId])
  @@map("user_unlocked_variants")
}
