# Runtime role.
# - `yarn api:dev` overrides APP_ROLE=api and runs migrations first.
# - `yarn worker:dev` overrides APP_ROLE=worker.
# - `yarn scheduler:dev` overrides APP_ROLE=scheduler.
APP_ROLE=api
NODE_ENV=development
HOST=0.0.0.0
PORT=3000
THROTTLE_DISABLED=false
INTERNAL_API_KEY=local-dev-internal-api-key

# Frontend/admin origins for CORS + OAuth redirects
WEB_ORIGIN=http://localhost:3001
ADMIN_ORIGIN=http://localhost:3002
FRONTEND_URL=http://localhost:3001
CLIENT_URL=http://localhost:3001
ALLOWED_CLIENT_URLS=http://localhost:3001,http://localhost:3002
CORS=http://localhost:3001,http://localhost:3002

# Refresh cookie options. Leave COOKIE_DOMAIN empty on localhost.
COOKIE_DOMAIN=
COOKIE_SAME_SITE=lax
COOKIE_SECURE=false

# MySQL / Prisma
DATABASE_URL=mysql://root:root@127.0.0.1:3306/audio_stories_dev

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_URL=redis://127.0.0.1:6379/0

# JWT / auth
JWT_ACCESS_SECRET=local-dev-access-secret-change-me
JWT_REFRESH_SECRET=local-dev-refresh-secret-change-me
JWT_ACCESS_TTL=7d
JWT_REFRESH_TTL=30d

# Seed defaults / local bootstrap
ADMIN_EMAIL=admin@localhost.test
ADMIN_PASSWORD=admin123

# SMTP / mail
SMTP_HOST=127.0.0.1
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@localhost.test
# Legacy alias still accepted by code
MAIL_FROM=no-reply@localhost.test

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google-redirect

# Upload / object storage
UPLOADTHING_TOKEN=
STORAGE_PROVIDER=r2
R2_TOKEN=
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
# Legacy alias still accepted by code
R2_SECRET_KEY_ID=
R2_BUCKET_NAME=audio-stories-dev
R2_URL=http://127.0.0.1:9000/audio-stories-dev
R2_ENDPOINT=http://127.0.0.1:9000

# Optional AWS S3 fallback
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-southeast-1
AWS_BUCKET_NAME=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
USD_TO_VND_RATE=25000

# VietQR / bank transfer
VIETQR_API_URL=https://api.vietqr.io/v2
VIETQR_CLIENT_ID=
VIETQR_API_KEY=
VIETQR_ACCOUNT_NO=123456789
VIETQR_ACCOUNT_NAME=NETVIET AUDIO DEV
VIETQR_BANK_ID=970418
# Legacy alias still accepted by code
VIETQR_ACQ_ID=970418
VIETQR_TEMPLATE=compact2
# Legacy alias still accepted by code
VIETQR_DEFAULT_TEMPLATE=compact2
VIETQR_QR_FORMAT=text
VIETQR_EXCHANGE_RATE=25000
VIETQR_ORDER_EXPIRY_MINUTES=15

# Casso webhook verification
CASSO_API_URL=https://oauth.casso.vn/v2
CASSO_API_KEY=
CASSO_SECURE_TOKEN=local-dev-casso-secure-token
CASSO_WEBHOOK_URL=http://localhost:3000/billing/webhook/casso

# Local/manual test helpers
E2E_CLEANUP=false
TEST_STORY_SLUG=
TEST_USER_TOKEN=
TEST_ADMIN_TOKEN=
