# Dependencies & build artifacts (rebuilt inside the image)
node_modules
dist
.yarn/cache
.yarn/install-state.gz

# VCS
.git
.gitignore

# Local env / secrets (must never leak into the image)
.env
.env.prod
.env.test
.env.example

# Logs
*.log

# Test artifacts
coverage
coverage-final.json
test
**/__tests__
**/*.spec.ts

# Runtime user-uploads (created on the host volume)
uploads

# Editor / OS / caches
.eslintcache
*.tsbuildinfo
.DS_Store
.idea
.vscode

# Local diagnostic outputs (generated by `yarn depcruise:graph`)
dependency-graph.svg

# Handoff notes (root-level, not under be/, but defensive)
.handoff-*.md
